    "[ACTION] Calcualate Tier One Amount": {
      "conditions": [
        {
          "variableName": "tier-one-total",
          "variableInput": "$current-stream-level",
          "type": "variableInsert",
          "displayName": "Set Total Tier One Count"
        },
        {
          "calc": "min",
          "value1": "current-stream-level",
          "value2": "max-mob-tier-001-count",
