          "displayName": "Custom User Command - Uncapped Spawns"
        },
        {
          "message": "After calculate",
          "type": "chat"
        }
      ],
      "allowsOtherEventsToTrigger": true
    },
    "[ACTION] Calculate Potion Tier": {
      "conditions": [
        {
          "calc": "mod",
          "value1": "current-stream-level",
          "value2": "5",
          "variableName": "potion-tier-remainder",
          "type": "math",
          "displayName": "Figure Out Level Remainder"
        },
        {
          "calc": "-",
          "value1": "current-stream-level",
          "value2": "potion-tier-remainder",
          "variableName": "potion-tier-base",
          "type": "math",
          "displayName": "Calculate Tier Base"
        },
        {
          "calc": "/",
          "value1": "potion-tier-base",
          "value2": "5",
          "variableName": "new-potion-tier-calc",
          "type": "math",
          "displayName": "Calculate Potion Tier"
        },
        {
          "calc": "round",
          "value1": "new-potion-tier-calc",
          "value2": "new-potion-tier-calc",
          "variableName": "new-potion-tier",
          "type": "math",
          "displayName": "Remove Decimal Point"
        },
        {
          "variableName": "potion-tier",
          "variableInput": "$new-potion-tier",
          "type": "variableInsert",
          "displayName": "Set Potion Tier"
        }
      ],
      "outcomes": [],
      "allowsOtherEventsToTrigger": true
    },
    "[ACTION] Calculate Tier 4 Amount": {
      "conditions": [
        {
          "optionalVariableName": "current-stream-level",
          "min": 16.0,
          "type": "range",
          "displayName": "Check if Elligibile for Tier 4"
        },
        {
          "calc": "-",
          "value1": "current-stream-level",
          "value2": "16",
          "variableName": "tier-four-difference",
          "type": "math",
          "displayName": "Calulate Difference"
        },
        {
          "calc": "+",
          "value1": "tier-four-difference",
          "value2": "1",
          "variableName": "tier-four-amount",
          "type": "math",
          "displayName": "Calculate Tier Four Amount"
        },
        {
          "variableName": "tier-four-total",
          "variableInput": "$tier-four-amount",
          "type": "variableInsert",
          "displayName": "Set Tier 4 Total"
        },
        {
          "calc": "min",
          "value1": "tier-four-amount",
          "value2": "max-mob-tier-004-count",
          "variableName": "tier-four-total",
          "type": "math",
          "displayName": "Calculate Tier Four Amount(NIN)"
