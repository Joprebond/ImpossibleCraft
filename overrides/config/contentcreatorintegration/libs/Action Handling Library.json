    },
    "[ACTION] Calcuate Max Mob Spawn Count": {
      "conditions": [],
      "outcomes": [
        {
          "message": "Before Calculate",
          "type": "chat"
        },
        {
          "condition": {
            "name": "[ACTION] Check if from Custom Command",
            "type": "constant",
            "displayName": "Check From Custom Command"
